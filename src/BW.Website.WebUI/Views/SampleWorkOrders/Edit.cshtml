@model BW.Website.WebUI.Models.SampleWorkOrders.SampleWorkOrderEditVm
@{
    ViewData["Title"] = "Edit Work Order";
}

<h1 class="text-2xl font-semibold">Edit Work Order</h1>

<form method="post" class="mt-6 space-y-4 app-card p-4">
    @Html.AntiForgeryToken()

    <div>
        <label class="block text-sm font-medium">Work Order Number</label>
        <input asp-for="WorkOrderNumber" class="app-input mt-1" />
        <span asp-validation-for="WorkOrderNumber" class="text-sm text-red-600"></span>
    </div>

    <div>
        <label class="block text-sm font-medium">Customer Name</label>
        <input asp-for="CustomerName" class="app-input mt-1" />
        <span asp-validation-for="CustomerName" class="text-sm text-red-600"></span>
    </div>

    <div>
        <label class="block text-sm font-medium">Due Date (UTC)</label>
        <input asp-for="DueDateUtc" type="datetime-local" class="app-input mt-1" />
        <span asp-validation-for="DueDateUtc" class="text-sm text-red-600"></span>
    </div>

    <div>
        <label class="block text-sm font-medium">Status</label>
        <input asp-for="Status" class="app-input mt-1" />
        <span asp-validation-for="Status" class="text-sm text-red-600"></span>
    </div>

    <div>
        <label class="block text-sm font-medium">Description</label>
        <textarea asp-for="Description" rows="4" class="app-input mt-1"></textarea>
        <span asp-validation-for="Description" class="text-sm text-red-600"></span>
    </div>

    <div class="flex items-center gap-2">
        <button type="submit" class="rounded-lg bg-brand px-4 py-2 text-sm font-semibold text-white hover:bg-brand-dark">
            Save
        </button>
        <a asp-action="Index" class="rounded-lg border px-4 py-2 text-sm" style="border-color: var(--color-border);">
            Cancel
        </a>
    </div>
</form>
